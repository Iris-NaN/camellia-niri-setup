{
    //_________\\ Default Modules //_________\\

    // taskbar
    "niri/taskbar": {
		"format": "{icon}",
		"icon-size": 18,
		"icon-theme": "Tela-circle-dracula",
        "spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},

    // network
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{icon}",
        "format-ethernet": "≤░Να",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>\nDownload: <b><span foreground='#99ffdd'>ΎΑβ {bandwidthDownBytes}</span></b>\nUpload: <b><span foreground='#ffcc66'>ΎΓΥ {bandwidthUpBytes}</span></b>",
        "format-linked": "≤░ΙΑ {ifname} (No IP)",
        "format-disconnected": "≤░Ψς ",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 2,
        "max-length": 30,
    	"format-icons": [
    		"≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // network speed
    "network#speed": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format": "<span foreground='#99ffdd'>ΎΑβ {bandwidthDownBytes}</span> <span foreground='#ffcc66'>ΎΓΥ {bandwidthUpBytes}</span>",
        "format-disconnected": "≤░Ψς ",
        "tooltip": false,
        "interval": 1,
        "max-length": 30,
    	"format-icons": [
    		"≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // idle inhibitor
    "idle_inhibitor": {
        "format": "{icon}",
        "start-activated": false,
            "format-icons": {
                "activated": "Ό░Χ",
                "deactivated": "≤░δΛ"
            },
        "tooltip-format-activated":"Caffeine Mode: Active \nNothing will be happen.",
        "tooltip-format-deactivated":"Caffeine Mode: Inactive\n\nIf there is no interaction with your\nsystem (mouse/keyboard), then \nScreen Lock: after 5 min \nScreen Off: after 10 min \nSleep: after 30 min"
    },

    // window
    "niri/window": {
        "format": "{}",
        "separate-outputs": true,
        "rewrite": {
            "^(.*)@[^:]+:(.*)$": "$1 ΎΤΚ :$2",
            "(.*) έΑΦ Mozilla Firefox": "$1 ≤░Ι╣",
            "(.*)Mozilla Firefox": "$1 Firefox ≤░Ι╣",
            "(.*) - Visual Studio Code": "$1 ≤░ρη",
            "(.*)Visual Studio Code": "$1 Code ≤░ρη",
            "(.*)Spotify.*": "$1 Spotify ≤░ΥΘ",
            "(.*)Steam": "$1 Steam ≤░ΥΥ",
            "(.*) - Discord": "$1 ΎΘ┐ ",
            "(.*?)-\\s*YouTube(.*)": "$1≤░ΩΔ", 
            "(.*?\\s)YouTube(.*)": "$1YouTube ≤░ΩΔ"
        },
        "max-length": 50
    },

    // language
    "niri/language": {
        "interval": 1,
        "format": "Όσξ {}",
        "format-uk": "Uk",
        "format-en": "US"
    },

    // workspaces
    "niri/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "format": "{icon}",
        // "format-icons": {
            // "1": "ΎΕι",
            // "2": "ΎΚρ",
            // "3": "ΎΕκ",
            // "4": "ΎΒ╗",
        //     "urgent": "ΎΒς",
        //     "focused": "ΎΗΤ",
        //     "default": "ΎΕΣ"
        // },
        "format-icons": {
            // for arch
            // "active": "≤░χψ",
            // "default": "Ό╗╛"

            // for fedora
            //  "active": "≤░μδ",  
            //  "default": "ΎΕΝ"

            // for opensuse
            // "active": "ΎΝΦ",
            // "default": "Όςψ"
          },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    //------took it from JaKooLit-------//

    "niri/workspaces#preview": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "sort-by-number": true,
        "show-special": false,
        "on-click": "activate",
        // "persistent-workspaces": {
        //     "*": 5
        //   },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        },
        "format": "{icon} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "ΎΒβ ",
        "window-rewrite": {		
            "title<.*amazon.*>": "ΎΚ░ ",
            "title<.*reddit.*>": "ΎΛΒ ",

            "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "ΌζΖ ",
            "class<zen>": "≤░░╖ ",
            "class<waterfox|waterfox-bin>": "Ό║Υ ",
            "class<microsoft-edge>": "ΎΛΓ ",
            "class<Chromium|Thorium|[Cc]hrome>": "ΎΚρ ",
            "class<brave-browser>": "ΏθοΒ ",
            "class<tor browser>": "ΎΞ▒ ",
            "class<firefox-developer-edition>": "≤░Ι╣ ",

            "class<kitty>": "≤░Εδ ",
            "class<kitty-dropterm>": "ΎΕι ",
            "class<com.mitchellh.ghostty>": " ΌηΧ",
            "class<org.wezfurlong.wezterm>": " ΌςΖ",

            "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "ΎΞ░ ",
            "class<eu.betterbird.Betterbird>": "ΎΞ░ ",
            "title<.*gmail.*>": "≤░Λτ ",

            "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "ΌΙΩ ",
            "class<discord|[Ww]ebcord|Vesktop>": "ΎΘ┐ ",
            "title<.*whatsapp.*>": "ΎΙ▓ ",
        "title<.*zapzap.*>": "ΎΙ▓ ",
            "title<.*messenger.*>": "ΎΚθ ",
            "title<.*facebook.*>": "ΎΓγ ",
            "title<.*instagram.*>": "≤░Μ╛ ",
            "title<.*reddit.*>": "ΎΛΒ ",
            "title<.*github.com.*>": "ΌεΚ ",


            "title<.*ChatGPT.*>": "≤░γσ ",
            "title<.*deepseek.*>": "≤░γσ ",
            "title<.*qwen.*>": "≤░γσ ",
            "class<subl>": "≤░Ζ│ ",
            "class<slack>": "ΎΗα ",

            "class<mpv>": "ΎΞχ ",
            "class<celluloid|Zoom>": "ΎΑ╜ ",
            "class<Cider>": "≤░ΟΗ ",
            "title<.*Picture-in-Picture.*>": "ΎΦυ ",
            "title<.*youtube.*>": "ΎΖς ",
            "class<vlc>": "≤░Χ╝ ",
            "title<.*cmus.*>": "ΎΑΒ ",
            "class<[Ss]potify>": "ΎΗ╝ ",

            "class<virt-manager>": "Όφ╗ ",
            "class<.virt-manager-wrapped>": "Όφ╗ ",
            "class<virtualbox manager>": "ΏθΤ╜ ",
            "title<virtualbox>": "ΏθΤ╜ ",
            "class<remmina>": "ΏθΨξΎ╕Π ",

            "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium|code>": "≤░ρη ",
        "class<dev.zed.Zed>": "≤░╡Β",
            "class<codeblocks>": "≤░Ζσ ",
            "title<.*github.*>": "ΎΕΥ ",
            "title<*[Pp]hotopea.*>": "Όη╕ ",
            "class<mousepad>": "ΎΖε ",
            "class<libreoffice-writer>": "Όγξ ",
            "class<libreoffice-startcenter>": "≤░ΠΗ ",
            "class<libreoffice-calc>": "ΎΞ╗ ",
            "title<.*nvim ~.*>": "ΎΞψ ",
            "title<.*vim.*>": "ΌθΖ ",
            "title<.*nvim.*>": "ΌθΖ ",
            "title<.*figma.*>": "Ό╜Θ ",
            "title<.*jira.*>": "Όζε ",
            "class<jetbrains-idea>": "Όη╡ ",

            "class<obs|com.obsproject.Studio>": "Όχπ ",

            "class<polkit-gnome-authentication-agent-1>": "≤░ΤΔ ",
            "class<nwg-look>": "ΌφΤ ",
            "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "≤▒κτ ",
            "class<steam>": "ΎΗ╢ ",
            "class<thunar|nemo>": "≤░ζ░ ",	
            "class<Gparted>":"ΎΔΘ",
            "class<gimp>": "ΎΝ╕ ",
            "class<emulator>": "ΏθΥ▒ ",
            "class<android-studio>": "ΎΖ╗ ",
            "class<org.pipewire.Helvum>": "≤░ΥΔ",
            "class<localsend>":"ΎΘι",
            "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "≤░╣δ",
            "class<org.bleachbit.BleachBit>": "ΎΘ╕ "
            }
        },

    // cpu
    "cpu": {
        "interval": 10,
        "format": "{icon0}{icon1}{icon2}{icon3}{icon4} {usage}%",
        "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"]
    },

    // memory
    "memory": {
        "interval": 2,
        "format": "≤░╛Ζ {used}GB",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "ΌΚο {used:0.1f}GB/{total:0.1f}GB"
    },

    // dik
    "disk": {
        "interval": 30,
        "format": "ΎΔΘ {free}",
        "path": "/",
        "tooltip": true,
        "tooltip-format": "Storage - {used} used out of {total} on {path} ({percentage_used}%)"
    },

    // temperature
    "temperature": {
        "thermal-zone": 1,
        "format": "ΎΜΚ {temperatureC}┬░C",
        "critical-threshold": 70,
        "format-critical": "ΎΜΘ {temperatureF}┬░F",
        "on-click": "kitty --title btop sh -c 'btop'"
    },
    
    // backlight
    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            "ΌΠΧ ",
            "ΌΠΩ ",
            "ΌΠγ ",
            "≤░Δζ ",
            "≤░Δη ",
            "≤░Δθ ",
            "≤░Δι "
        ],
        "tooltip-format": "backlight {percent}%",
        "icon-size": 10,
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "~/.config/niri/scripts/brightness.sh up",
        "on-scroll-down": "~/.config/niri/scripts/brightness.sh down",
        "smooth-scrolling-threshold": 1
    },

    // tray
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    // clock
    "clock": {
        "format": "ΎΑΩ {:%mόεΙ%dόΩξ %H:%M}",
        "format-alt": "≤░Δφ {:%Yί╣┤%mόεΙ%dόΩξ %A}",
        "format-alt-click": "click",
        "on-click-right": "zenity --calendar --title='όΩξίΟΗ' --text='ώΑΚόΜσόΩξόεθ'",
        "timezone": "Asia/Shanghai",
        "locale": "zh_CN.UTF-8",
        "tooltip": true,
        "tooltip-format": "<span size='11pt' font='WenQuanYi Zen Hei Mono'>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "format": {
                "months": "<span color='#dbe3c8'><b>{}</b></span>",
                "weekdays": "<span color='#A4BCA4'><b>{}</b></span>",
                "today": "<span color='#D2CE4B'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_down",
            "on-scroll-down": "shift_up"
        }
    },

    // battery
    "battery": {
	//"interval": 5,
	"align": 0,
	"rotate": 0,
	"full-at": 100,
	"design-capacity": false,
	"states": {
		"good": 95,
		"warning": 30,
		"critical": 15
	},
	"format": "{icon} {capacity}%",
	"format-charging": "ΎΔπ {capacity}%",
	"format-plugged": "≤▒αΨ {capacity}%",
	"format-alt-click": "click",
	"format-full": "{icon} Full",
	"format-alt": "{icon} {time}",
	"format-icons": [
		"≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"
	    ],
	"format-time": "{H}h {M}min",
	"tooltip": true,
	"tooltip-format": "{timeTo} {power}w",
    },

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "on-scroll-up": "~/.config/niri/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/niri/scripts/volumecontrol.sh --dec",
        "orientation": "vertical"
    },

    // pulseaudio
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "ΎΣο ",
        "tooltip": false,
        "on-click": "~/.config/niri/scripts/volumecontrol.sh --toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/niri/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/niri/scripts/volumecontrol.sh --dec",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
        }
    },

    // pulseautio mic
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "on-click": "pamixer --default-source -t",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },

    // mpris ( media player )
    "mpris": {
        "interval": 2,
        "format": "{player_icon}  {status_icon}",
        "format-paused": "{player_icon}  {status_icon}",
        "tooltip": true,
        "tooltip-format": "{dynamic}",
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next",
        "scroll-step": 5.0,
        "on-scroll-up": "~/.config/niri/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/niri/scripts/volumecontrol.sh --dec",
        "smooth-scrolling-threshold": 1,
        "player-icons": {
            "chromium": "ΎΚρ",
            "default": "ΎΑζ",
            "firefox": "ΎΚσ",
            "kdeconnect": "Ύαθ",
            "mopidy": "ΎΑΒ",
            "mpv": "≤░Ρ╣",
            "spotify": "ΎΗ╝",
            "vlc": "≤░Χ╝"
        },
        "status-icons": {
            "paused": "≤░Πν ",
            "playing": "ΎΒΜ ",
            "stopped": "ΎΒΞ"
        },
        "max-length": 30
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "≤▒Υη",
        "performance": "≤▒Υη",
        "balanced": "ΎΚΟ",
        "power-saver": "ΎΒυ"
      }
    },

    // "user": {
    //     "format": "{user}",
    //     "interval": 60,
    //     "height": 30,
    //     "width": 30,
    //     "icon": true,
    // },

    // keyboard status
    // "keyboard-state": {
	// "numlock": true,
	// "capslock": true,
	// "format": {
	// 	"numlock": "N {icon}",
	// 	"capslock": "≤░ςδ {icon}"
	//     },
	// "format-icons": {
	// 	"locked": "ΎΑμ",
	// 	"unlocked": "ΎΓε"
	//     }
    // },
}
