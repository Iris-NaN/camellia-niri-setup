{
    //_________\\ Default Modules //_________\\

    // taskbar
    "niri/taskbar": {
		"format": "{icon}",
		"icon-size": 18,
		"icon-theme": "Tela-circle-dracula",
        "spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},

    // network
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{icon}",
        "format-ethernet": "ůįĆė",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>\nDownload: <b><span foreground='#99ffdd'>ÔÄô {bandwidthDownBytes}</span></b>\nUpload: <b><span foreground='#ffcc66'>Ôāď {bandwidthUpBytes}</span></b>",
        "format-linked": "ůįąÄ {ifname} (No IP)",
        "format-disconnected": "ůįĖ™ ",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 2,
        "max-length": 30,
    	"format-icons": [
    		"ůį§Į", "ůį§ü", "ůį§Ę", "ůį§•", "ůį§®"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // network speed
    "network#speed": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format": "<span foreground='#99ffdd'>ÔÄô {bandwidthDownBytes}</span> <span foreground='#ffcc66'>Ôāď {bandwidthUpBytes}</span>",
        "format-disconnected": "ůįĖ™ ",
        "tooltip": false,
        "interval": 1,
        "max-length": 30,
    	"format-icons": [
    		"ůį§Į", "ůį§ü", "ůį§Ę", "ůį§•", "ůį§®"
    	],
        "on-click-right": "kitty -e nmtui"
    },

    // idle inhibitor
    "idle_inhibitor": {
        "format": "{icon}",
        "start-activated": false,
            "format-icons": {
                "activated": "Óįē",
                "deactivated": "ůįõä"
            },
        "tooltip-format-activated":"Caffeine Mode: Active \nNothing will be happen.",
        "tooltip-format-deactivated":"Caffeine Mode: Inactive\n\nIf there is no interaction with your\nsystem (mouse/keyboard), then \nScreen Lock: after 5 min \nScreen Off: after 10 min \nSleep: after 30 min"
    },

    // window
    "niri/window": {
        "format": "{}",
        "separate-outputs": true,
        "rewrite": {
            "^(.*)@[^:]+:(.*)$": "$1 ÔíČ :$2",
            "(.*) ‚ÄĒ Mozilla Firefox": "$1 ůįąĻ",
            "(.*)Mozilla Firefox": "$1 Firefox ůįąĻ",
            "(.*) - Visual Studio Code": "$1 ůį®ě",
            "(.*)Visual Studio Code": "$1 Code ůį®ě",
            "(.*)Spotify.*": "$1 Spotify ůįďá",
            "(.*)Steam": "$1 Steam ůįďď",
            "(.*) - Discord": "$1 ÔáŅ ",
            "(.*?)-\\s*YouTube(.*)": "$1ůįóÉ", 
            "(.*?\\s)YouTube(.*)": "$1YouTube ůįóÉ"
        },
        "max-length": 50
    },

    // language
    "niri/language": {
        "interval": 1,
        "format": "Ó©• {}",
        "format-uk": "Uk",
        "format-en": "US"
    },

    // workspaces
    "niri/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "on-scroll-up": "nirictl dispatch workspace e-1",
        "on-scroll-down": "nirictl dispatch workspace e+1",
        "format": "{icon}",
        // "format-icons": {
            // "1": "ÔĄ†",
            // "2": "ÔČ®",
            // "3": "ÔĄ°",
            // "4": "ÔĀĽ",
        //     "urgent": "ÔĀ™",
        //     "focused": "ÔÜí",
        //     "default": "ÔĄĎ"
        // },
        "format-icons": {
            // for arch
            // "active": "ůįģĮ",
            // "default": "ÓĽĺ"

            // for fedora
            //  "active": "ůį£õ",  
            //  "default": "ÔĄĆ"

            // for opensuse
            // "active": "ÔĆĒ",
            // "default": "Ó™Į"
          },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    //------took it from JaKooLit-------//

    "niri/workspaces#preview": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "sort-by-number": true,
        "show-special": false,
        "on-click": "activate",
        "on-scroll-up": "nirictl dispatch workspace e+1",
        "on-scroll-down": "nirictl dispatch workspace e-1",
        // "persistent-workspaces": {
        //     "*": 5
        //   },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        },
        "format": "{icon} {windows}",
        "format-window-separator": " ",
        "window-rewrite-default": "ÔĀô ",
        "window-rewrite": {		
            "title<.*amazon.*>": "ÔČį ",
            "title<.*reddit.*>": "ÔäĀ ",

            "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "ÓĚÖ ",
            "class<zen>": "ůįį∑ ",
            "class<waterfox|waterfox-bin>": "Óļď ",
            "class<microsoft-edge>": "Ôäā ",
            "class<Chromium|Thorium|[Cc]hrome>": "ÔČ® ",
            "class<brave-browser>": "ūü¶Ā ",
            "class<tor browser>": "ÔćĪ ",
            "class<firefox-developer-edition>": "ůįąĻ ",

            "class<kitty>": "ůįĄõ ",
            "class<kitty-dropterm>": "ÔĄ† ",
            "class<com.mitchellh.ghostty>": " Óěē",
            "class<org.wezfurlong.wezterm>": " Ó™Ö",

            "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "Ôćį ",
            "class<eu.betterbird.Betterbird>": "Ôćį ",
            "title<.*gmail.*>": "ůįäę ",

            "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "Óąó ",
            "class<discord|[Ww]ebcord|Vesktop>": "ÔáŅ ",
            "title<.*whatsapp.*>": "Ôą≤ ",
        "title<.*zapzap.*>": "Ôą≤ ",
            "title<.*messenger.*>": "ÔČü ",
            "title<.*facebook.*>": "Ôāö ",
            "title<.*instagram.*>": "ůįčĺ ",
            "title<.*reddit.*>": "ÔäĀ ",
            "title<.*github.com.*>": "ÓúČ ",


            "title<.*ChatGPT.*>": "ůįö© ",
            "title<.*deepseek.*>": "ůįö© ",
            "title<.*qwen.*>": "ůįö© ",
            "class<subl>": "ůįÖ≥ ",
            "class<slack>": "ÔÜė ",

            "class<mpv>": "Ôćģ ",
            "class<celluloid|Zoom>": "ÔÄĹ ",
            "class<Cider>": "ůįéÜ ",
            "title<.*Picture-in-Picture.*>": "ÔĒ¨ ",
            "title<.*youtube.*>": "ÔÖ™ ",
            "class<vlc>": "ůįēľ ",
            "title<.*cmus.*>": "ÔÄĀ ",
            "class<[Ss]potify>": "ÔÜľ ",

            "class<virt-manager>": "Ó≠Ľ ",
            "class<.virt-manager-wrapped>": "Ó≠Ľ ",
            "class<virtualbox manager>": "ūüíĹ ",
            "title<virtualbox>": "ūüíĹ ",
            "class<remmina>": "ūüĖ•ÔłŹ ",

            "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium|code>": "ůį®ě ",
        "class<dev.zed.Zed>": "ůįĶĀ",
            "class<codeblocks>": "ůįÖ© ",
            "title<.*github.*>": "ÔĄď ",
            "title<*[Pp]hotopea.*>": "Óěł ",
            "class<mousepad>": "ÔÖú ",
            "class<libreoffice-writer>": "Óö• ",
            "class<libreoffice-startcenter>": "ůįŹÜ ",
            "class<libreoffice-calc>": "ÔćĽ ",
            "title<.*nvim ~.*>": "ÔćĮ ",
            "title<.*vim.*>": "ÓüÖ ",
            "title<.*nvim.*>": "ÓüÖ ",
            "title<.*figma.*>": "ÓĹá ",
            "title<.*jira.*>": "ÓĚú ",
            "class<jetbrains-idea>": "ÓěĶ ",

            "class<obs|com.obsproject.Studio>": "Óģß ",

            "class<polkit-gnome-authentication-agent-1>": "ůįíÉ ",
            "class<nwg-look>": "Ó≠í ",
            "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "ůĪ°ę ",
            "class<steam>": "ÔÜ∂ ",
            "class<thunar|nemo>": "ůįĚį ",	
            "class<Gparted>":"ÔÉá",
            "class<gimp>": "ÔĆł ",
            "class<emulator>": "ūüďĪ ",
            "class<android-studio>": "ÔÖĽ ",
            "class<org.pipewire.Helvum>": "ůįďÉ",
            "class<localsend>":"Ôá†",
            "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "ůįĻõ",
            "class<org.bleachbit.BleachBit>": "Ôáł "
            }
        },

    // cpu
    "cpu": {
        "interval": 10,
        "format": "{icon0}{icon1}{icon2}{icon3}{icon4} {usage}%",
        "format-icons": ["‚ĖĀ", "‚Ėā", "‚ĖÉ", "‚ĖĄ", "‚ĖÖ", "‚ĖÜ", "‚Ėá", "‚Ėą"]
    },

    // memory
    "memory": {
        "interval": 2,
        "format": "ůįĺÖ {used}GB",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "ÓČ¶ {used:0.1f}GB/{total:0.1f}GB"
    },

    // dik
    "disk": {
        "interval": 30,
        "format": "ÔÉá {free}",
        "path": "/",
        "tooltip": true,
        "tooltip-format": "Storage - {used} used out of {total} on {path} ({percentage_used}%)"
    },

    // temperature
    "temperature": {
        "thermal-zone": 1,
        "format": "ÔčČ {temperatureC}¬įC",
        "critical-threshold": 70,
        "format-critical": "Ôčá {temperatureF}¬įF",
        "on-click": "kitty --title btop sh -c 'btop'"
    },
    
    // backlight
    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            "ÓŹē ",
            "ÓŹó ",
            "ÓŹö ",
            "ůįÉĚ ",
            "ůįÉě ",
            "ůįÉü ",
            "ůįÉ† "
        ],
        "tooltip-format": "backlight {percent}%",
        "icon-size": 10,
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "~/.config/niri/scripts/brightness.sh up",
        "on-scroll-down": "~/.config/niri/scripts/brightness.sh down",
        "smooth-scrolling-threshold": 1
    },

    // tray
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    // clock
    "clock": {
        "format": "ÔÄó {:%mśúą%dśó• %H:%M}",
        "format-alt": "ůįÉ≠ {:%YŚĻī%mśúą%dśó• %A}",
        "format-alt-click": "click",
        "on-click-right": "zenity --calendar --title='śó•ŚéÜ' --text='ťÄČśč©śó•śúü'",
        "timezone": "Asia/Shanghai",
        "locale": "zh_CN.UTF-8",
        "tooltip": true,
        "tooltip-format": "<span size='11pt' font='WenQuanYi Zen Hei Mono'>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "format": {
                "months": "<span color='#dbe3c8'><b>{}</b></span>",
                "weekdays": "<span color='#A4BCA4'><b>{}</b></span>",
                "today": "<span color='#D2CE4B'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_down",
            "on-scroll-down": "shift_up"
        }
    },

    // battery
    "battery": {
	//"interval": 5,
	"align": 0,
	"rotate": 0,
	"full-at": 100,
	"design-capacity": false,
	"states": {
		"good": 95,
		"warning": 30,
		"critical": 15
	},
	"format": "{icon} {capacity}%",
	"format-charging": "ÔÉß {capacity}%",
	"format-plugged": "ůĪėĖ {capacity}%",
	"format-alt-click": "click",
	"format-full": "{icon} Full",
	"format-alt": "{icon} {time}",
	"format-icons": [
		"ůįāé", "ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"
	    ],
	"format-time": "{H}h {M}min",
	"tooltip": true,
	"tooltip-format": "{timeTo} {power}w",
    },

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "on-scroll-up": "~/.config/niri/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/niri/scripts/volumecontrol.sh --dec",
        "orientation": "vertical"
    },

    // pulseaudio
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "ÔĎ¶ ",
        "tooltip": false,
        "on-click": "~/.config/niri/scripts/volumecontrol.sh --toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/niri/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/niri/scripts/volumecontrol.sh --dec",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ÔÄ•",
            "hands-free": "ÔÄ•",
            "headset": "ÔÄ•",
            "phone": "Ôāē",
            "default": ["ÔÄ¶", "ÔÄß", "ÔÄ® "]
        }
    },

    // pulseautio mic
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ÔĄį {volume}%",
        "format-source-muted": "ÔĄĪ",
        "on-click": "pamixer --default-source -t",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },

    // mpris ( media player )
    "mpris": {
        "interval": 2,
        "format": "{player_icon}  {status_icon}",
        "format-paused": "{player_icon}  {status_icon}",
        "tooltip": true,
        "tooltip-format": "{dynamic}",
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next",
        "scroll-step": 5.0,
        "on-scroll-up": "~/.config/niri/scripts/volumecontrol.sh --inc",
        "on-scroll-down": "~/.config/niri/scripts/volumecontrol.sh --dec",
        "smooth-scrolling-threshold": 1,
        "player-icons": {
            "chromium": "ÔČ®",
            "default": "ÔÄĚ",
            "firefox": "ÔČ©",
            "kdeconnect": "Ôėü",
            "mopidy": "ÔÄĀ",
            "mpv": "ůįźĻ",
            "spotify": "ÔÜľ",
            "vlc": "ůįēľ"
        },
        "status-icons": {
            "paused": "ůįŹ§ ",
            "playing": "ÔĀč ",
            "stopped": "ÔĀć"
        },
        "max-length": 30
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "ůĪďě",
        "performance": "ůĪďě",
        "balanced": "ÔČé",
        "power-saver": "ÔĀ¨"
      }
    },

    // "user": {
